rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/(default)/documents/usuarios/$(uid);
    }

    function hasUserProfile() {
      return signedIn() && firestore.exists(userPath(request.auth.uid));
    }

    function currentProfile() {
      return firestore.get(userPath(request.auth.uid)).data;
    }

    function isActiveUser() {
      return hasUserProfile() && currentProfile().activo == true;
    }

    function hasRole(role) {
      return isActiveUser() && currentProfile().rol == role;
    }

    function isAdmin() {
      return hasRole('ADMIN') || hasRole('SUPERADMIN');
    }

    function isSuperAdmin() {
      return hasRole('SUPERADMIN');
    }

    function isAdminVisibleEstado(estado) {
      return estado in [
        'ENVIADA',
        'enviada',
        'Enviada',
        'APROBADA',
        'aprobada',
        'Aprobada',
        'RECHAZADA',
        'rechazada',
        'Rechazada'
      ];
    }

    function rendicionPath(rendicionId) {
      return /databases/(default)/documents/rendiciones/$(rendicionId);
    }

    function rendicionExists(rendicionId) {
      return firestore.exists(rendicionPath(rendicionId));
    }

    function rendicionData(rendicionId) {
      return firestore.get(rendicionPath(rendicionId)).data;
    }

    function isOwnRendicion(rendicionId) {
      let rendicion = rendicionData(rendicionId);

      return signedIn() && (
        rendicion.ownerUid == request.auth.uid ||
        rendicion.usuario_id == request.auth.uid ||
        rendicion.uid == request.auth.uid
      );
    }

    function canReadRendicionAdjunto(rendicionId) {
      let rendicion = rendicionData(rendicionId);

      return isOwnRendicion(rendicionId) ||
        isSuperAdmin() ||
        (hasRole('ADMIN') && isAdminVisibleEstado(rendicion.estado));
    }

    function isEditableRendicion(rendicionId) {
      let rendicion = rendicionData(rendicionId);

      return rendicion.estado in ['BORRADOR', 'RECHAZADA'];
    }

    function validUploadMetadata(rendicionId, gastoId) {
      return request.resource.metadata.ownerUid == request.auth.uid &&
        request.resource.metadata.rendicionId == rendicionId &&
        request.resource.metadata.gastoId == gastoId &&
        request.resource.metadata.adjuntoId is string &&
        request.resource.metadata.adjuntoId.size() > 0;
    }

    function canCreateAdjunto(rendicionId) {
      return !rendicionExists(rendicionId) ||
        (
          isOwnRendicion(rendicionId) &&
          isEditableRendicion(rendicionId)
        );
    }

    function canUpdateAdjunto(rendicionId) {
      return (
          rendicionExists(rendicionId) &&
          isOwnRendicion(rendicionId) &&
          isEditableRendicion(rendicionId)
        ) ||
        (
          !rendicionExists(rendicionId) &&
          resource.metadata.ownerUid == request.auth.uid
        );
    }

    function canDeleteAdjunto(rendicionId) {
      return (
          rendicionExists(rendicionId) &&
          isOwnRendicion(rendicionId) &&
          isEditableRendicion(rendicionId)
        ) ||
        (
          !rendicionExists(rendicionId) &&
          resource.metadata.ownerUid == request.auth.uid
        );
    }

    function canReadOrphanAdjunto() {
      return resource.metadata.ownerUid == request.auth.uid;
    }

    function isAllowedAdjuntoContentType() {
      return request.resource.contentType == 'image/jpeg' ||
        request.resource.contentType == 'image/png' ||
        request.resource.contentType == 'application/pdf';
    }

    function isAllowedAdjuntoSize() {
      return request.resource.size <= 5 * 1024 * 1024;
    }

    match /adjuntos/{rendicionId}/{gastoId}/{fileName} {
      allow read: if signedIn() &&
        (
          (
            rendicionExists(rendicionId) &&
            canReadRendicionAdjunto(rendicionId)
          ) ||
          (
            !rendicionExists(rendicionId) &&
            canReadOrphanAdjunto()
          )
        );

      allow create: if isActiveUser() &&
        canCreateAdjunto(rendicionId) &&
        validUploadMetadata(rendicionId, gastoId) &&
        isAllowedAdjuntoContentType() &&
        isAllowedAdjuntoSize();

      allow update: if isActiveUser() &&
        canUpdateAdjunto(rendicionId) &&
        validUploadMetadata(rendicionId, gastoId) &&
        isAllowedAdjuntoContentType() &&
        isAllowedAdjuntoSize();

      allow delete: if isActiveUser() &&
        canDeleteAdjunto(rendicionId);
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
