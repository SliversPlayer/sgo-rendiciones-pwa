[debug] [2026-06-06T15:55:48.452Z] <<< [apiv2][body] POST https://firebaserules.googleapis.com/v1/projects/sgo-rendiciones/rulesets {"name":"projects/sgo-rendiciones/rulesets/63d86fea-9df6-4631-b31a-35692199f40c","source":{"files":[{"content":"rules_version = '2';\n\nservice firebase.storage {\n  match /b/{bucket}/o {\n    function signedIn() {\n      return request.auth != null;\n    }\n\n    function userPath(uid) {\n      return /databases/(default)/documents/usuarios/$(uid);\n    }\n\n    function hasUserProfile() {\n      return signedIn() && firestore.exists(userPath(request.auth.uid));\n    }\n\n    function currentProfile() {\n      return firestore.get(userPath(request.auth.uid)).data;\n    }\n\n    function isActiveUser() {\n      return hasUserProfile() && currentProfile().activo == true;\n    }\n\n    function hasRole(role) {\n      return isActiveUser() && currentProfile().rol == role;\n    }\n\n    function isAdmin() {\n      return hasRole('ADMIN') || hasRole('SUPERADMIN');\n    }\n\n    function isSuperAdmin() {\n      return hasRole('SUPERADMIN');\n    }\n\n    function isAdminVisibleEstado(estado) {\n      return estado in [\n        'ENVIADA',\n        'enviada',\n        'Enviada',\n        'APROBADA',\n        'aprobada',\n        'Aprobada',\n        'RECHAZADA',\n        'rechazada',\n        'Rechazada'\n      ];\n    }\n\n    function rendicionPath(rendicionId) {\n      return /databases/(default)/documents/rendiciones/$(rendicionId);\n    }\n\n    function rendicionExists(rendicionId) {\n      return firestore.exists(rendicionPath(rendicionId));\n    }\n\n    function rendicionData(rendicionId) {\n      return firestore.get(rendicionPath(rendicionId)).data;\n    }\n\n    function isOwnRendicion(rendicionId) {\n      let rendicion = rendicionData(rendicionId);\n\n      return signedIn() && (\n        rendicion.ownerUid == request.auth.uid ||\n        rendicion.usuario_id == request.auth.uid ||\n        rendicion.uid == request.auth.uid\n      );\n    }\n\n    function canReadRendicionAdjunto(rendicionId) {\n      let rendicion = rendicionData(rendicionId);\n\n      return isOwnRendicion(rendicionId) ||\n        isSuperAdmin() ||\n        (hasRole('ADMIN') && isAdminVisibleEstado(rendicion.estado));\n    }\n\n    function isEditableRendicion(rendicionId) {\n      let rendicion = rendicionData(rendicionId);\n\n      return rendicion.estado in ['BORRADOR', 'RECHAZADA'];\n    }\n\n    function validUploadMetadata(rendicionId, gastoId) {\n      return request.resource.metadata.ownerUid == request.auth.uid &&\n        request.resource.metadata.rendicionId == rendicionId &&\n        request.resource.metadata.gastoId == gastoId &&\n        request.resource.metadata.adjuntoId is string &&\n        request.resource.metadata.adjuntoId.size() > 0;\n    }\n\n    function canCreateAdjunto(rendicionId) {\n      return !rendicionExists(rendicionId) ||\n        (\n          isOwnRendicion(rendicionId) &&\n          isEditableRendicion(rendicionId)\n        );\n    }\n\n    function canUpdateAdjunto(rendicionId) {\n      return (\n          rendicionExists(rendicionId) &&\n          isOwnRendicion(rendicionId) &&\n          isEditableRendicion(rendicionId)\n        ) ||\n        (\n          !rendicionExists(rendicionId) &&\n          resource.metadata.ownerUid == request.auth.uid\n        );\n    }\n\n    function canDeleteAdjunto(rendicionId) {\n      return (\n          rendicionExists(rendicionId) &&\n          isOwnRendicion(rendicionId) &&\n          isEditableRendicion(rendicionId)\n        ) ||\n        (\n          !rendicionExists(rendicionId) &&\n          resource.metadata.ownerUid == request.auth.uid\n        );\n    }\n\n    function canReadOrphanAdjunto() {\n      return resource.metadata.ownerUid == request.auth.uid;\n    }\n\n    function isAllowedAdjuntoContentType() {\n      return request.resource.contentType == 'image/jpeg' ||\n        request.resource.contentType == 'image/png' ||\n        request.resource.contentType == 'application/pdf';\n    }\n\n    function isAllowedAdjuntoSize() {\n      return request.resource.size <= 5 * 1024 * 1024;\n    }\n\n    match /adjuntos/{rendicionId}/{gastoId}/{fileName} {\n      allow read: if signedIn() &&\n        (\n          (\n            rendicionExists(rendicionId) &&\n            canReadRendicionAdjunto(rendicionId)\n          ) ||\n          (\n            !rendicionExists(rendicionId) &&\n            canReadOrphanAdjunto()\n          )\n        );\n\n      allow create: if isActiveUser() &&\n        canCreateAdjunto(rendicionId) &&\n        validUploadMetadata(rendicionId, gastoId) &&\n        isAllowedAdjuntoContentType() &&\n        isAllowedAdjuntoSize();\n\n      allow update: if isActiveUser() &&\n        canUpdateAdjunto(rendicionId) &&\n        validUploadMetadata(rendicionId, gastoId) &&\n        isAllowedAdjuntoContentType() &&\n        isAllowedAdjuntoSize();\n\n      allow delete: if isActiveUser() &&\n        canDeleteAdjunto(rendicionId);\n    }\n\n    match /{allPaths=**} {\n      allow read, write: if false;\n    }\n  }\n}\n","name":"storage.rules"}]},"createTime":"2026-06-06T17:05:26.825583Z","metadata":{"services":["firebase.storage"]}}
